{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "dfdevecom"
		},
		"LS_SQL_LKUP_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQL_LKUP'"
		},
		"LS_SQL_PARQUE_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_SQL_PARQUE'"
		},
		"LS_SQL_PARQUE1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_SQL_PARQUE1'"
		},
		"LS_SQL_LKUP_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": ".\\SQLEXPRESS"
		},
		"LS_SQL_LKUP_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "EcomApplication"
		},
		"LS_SQL_LKUP_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sa"
		},
		"LS_SQL_PARQUE_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsecomproject.dfs.core.windows.net/"
		},
		"LS_SQL_PARQUE1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsecomproject.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "dfdevecom_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_SQL_PARQUE_accountKey": {
						"value": "[parameters('LS_SQL_PARQUE_accountKey')]"
					},
					"LS_SQL_PARQUE1_accountKey": {
						"value": "[parameters('LS_SQL_PARQUE1_accountKey')]"
					},
					"LS_SQL_LKUP_password": {
						"value": "[parameters('LS_SQL_LKUP_password')]"
					},
					"LS_SQL_PARQUE_properties_typeProperties_url": {
						"value": "[parameters('LS_SQL_PARQUE_properties_typeProperties_url')]"
					},
					"LS_SQL_PARQUE1_properties_typeProperties_url": {
						"value": "[parameters('LS_SQL_PARQUE1_properties_typeProperties_url')]"
					},
					"LS_SQL_LKUP_properties_typeProperties_server": {
						"value": "[parameters('LS_SQL_LKUP_properties_typeProperties_server')]"
					},
					"LS_SQL_LKUP_properties_typeProperties_database": {
						"value": "[parameters('LS_SQL_LKUP_properties_typeProperties_database')]"
					},
					"LS_SQL_LKUP_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQL_LKUP_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}